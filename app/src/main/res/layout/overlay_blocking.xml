<?xml version="1.0" encoding="utf-8"?>
<!-- Overlay 2: Bloqueo interactivo (2do cartel) -->
<!-- Se muestra cuando se detectan keywords de escaneo QR en pantalla -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#EDF44336"
    android:padding="20dp"
    android:elevation="32dp">

    <TextView
        android:id="@+id/tvBlockingTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚫 ESCANEO QR DETECTADO"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:paddingBottom="12dp" />

    <TextView
        android:id="@+id/tvBlockingMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Se detectaron botones de escaneo en pantalla."
        android:textSize="13sp"
        android:textColor="#FFEEEE"
        android:lineSpacingExtra="4dp"
        android:paddingBottom="20dp" />

    <!-- Botones en fila -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="✅ Cancelar"
            android:backgroundTint="#2E7D32"
            android:textColor="@android:color/white"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnContinue"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="⚠️ Continuar"
            android:backgroundTint="#37474F"
            android:textColor="@android:color/white" />

    </LinearLayout>

</LinearLayout>
